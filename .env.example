# ── API KEYS (IA Providers) ──
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
CEREBRAS_API_KEY=...
MISTRAL_API_KEY=...
GITHUB_TOKEN=ghp_...
PEXELS_API_KEY=...

# ── Database (Vercel Postgres / Neon) ──
DATABASE_URL=postgres://user:pass@ep-xxx.aws.neon.tech/neondb

# ── Authentication ──
# Générer le hash : node scripts/generate-hash.js <mot-de-passe>
PASSWORD_HASH=
SESSION_SECRET=generer-avec-crypto-randomBytes-32-hex

# ── CORS ──
ALLOWED_ORIGIN=http://localhost:3000,https://articles-immeit.vercel.app

# ── SharePoint / Microsoft Graph (optionnel) ──
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_HOSTNAME=
SHAREPOINT_SITE_PATH=
SHAREPOINT_FILE_ID=
SHAREPOINT_SHEET_NAME=Suivi Demandes 2026

# ── CRON / Sync automatisé ──
# Secret partagé entre Vercel et GitHub Actions pour le sync automatique
# À définir aussi dans les secrets GitHub (Settings → Secrets → Actions → CRON_SECRET)
CRON_SECRET=generer-une-chaine-aleatoire

# ── Logging ──
LOG_LEVEL=info

# ── SMTP (email alerts, optionnel) ──
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=IMMEIT Hub <email@domain.com>
ALERT_EMAIL_TO=
