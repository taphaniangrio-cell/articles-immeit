{
  "name": "immeit-hub",
  "version": "2.0.0",
  "description": "Générateur d'articles LinkedIn pour IMMEIT — maintenance industrielle, fiabilité, GMAO",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node server.mjs",
    "local": "start.bat",
    "db:init": "psql $DATABASE_URL -f db/schema.sql",
    "db:migrate": "node scripts/migrate-supabase.js",
    "db:transfer": "node scripts/transfer-data.js",
    "hash": "node scripts/generate-hash.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@azure/msal-node": "^5.3.1",
    "bcryptjs": "^3.0.3",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.0"
  },
  "optionalDependencies": {
    "@azure/identity": "^4.13.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taphaniangrio-cell/immeit-hub.git"
  },
  "keywords": [
    "immeit",
    "articles",
    "maintenance",
    "fiabilite",
    "gmao"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
